<%- include('partials/MasterHeader') %>
</div>
<div class="col-md-10">
  <h2 class="text-2xl font-bold mb-4">My Purchases</h2>

  <button id="toggleButton" class="mb-4 bg-blue-700 text-white px-4 py-2 rounded">Show RP Orders</button>

  <div id="accountsPurchasedTable" class="overflow-x-auto">
    <table class="table-auto border-collapse border border-gray-600">
      <thead class="bg-gray-800 text-white">
        <tr>
          <th class="px-4 py-2">Purchase Date</th>
          <th class="px-4 py-2">Username</th>
          <th class="px-4 py-2">Password</th>
          <th class="px-4 py-2">Region</th>
          <th class="px-4 py-2">Blue Essence</th>
          <th class="px-4 py-2">Level</th>
          <th class="px-4 py-2">Skin List</th>
          <th class="px-4 py-2">Price</th>
        </tr>
      </thead>
      <tbody class="text-white bg-gray-900">
        <% if (accountsPurchased.length > 0) { %>
          <% accountsPurchased.forEach((purchase, index) => { %>
            <tr>
              <td class="border border-gray-600 px-4 py-2"><%= purchase.formattedDate %></td>
              <% const accountDetails = accountsDetails[index]; %>
              <% if (accountDetails) { %>
                <td class="border border-gray-600 px-4 py-2"><%= accountDetails.username %></td>
                <td class="border border-gray-600 px-4 py-2">Check your email</td>
                <td class="border border-gray-600 px-4 py-2"><%= accountDetails.region %></td>
                <td class="border border-gray-600 px-4 py-2"><%= (accountDetails.blueessence >= 10000) ? (Math.floor(accountDetails.blueessence / 10000) * 10000 + '+') : '<10,000' %></td>
                <td class="border border-gray-600 px-4 py-2"><%= accountDetails.level %></td>
                <td class="border border-gray-600 px-4 py-2">
                  <% if (accountDetails && accountDetails.skinNames) { %>
                    <div class="btn-group dropup">
                      <button type="button" class="flex text-sm bg-gray-900 rounded-full md:me-0" id="user-menu-button" aria-expanded="false" data-dropdown-toggle="skin-dropdown" data-dropdown-placement="bottom">
                        <span class="block bg-blue-800 p-1 rounded text-sm text-white dark:text-white text-xl font-semibold"> Show Skin List</span>
                      </button>
                      <div class="z-50 hidden my-4 text-base list-none bg-white divide-y divide-gray-100 rounded-lg shadow dark:bg-gray-700 dark:divide-gray-600" id="skin-dropdown">
                        <ul class="dropdown-menu">
                          <% accountDetails.skinNames.forEach(skinName => { %>
                            <li>
                              <% if (accountDetails.highestRarityName.includes(skinName)) { %>
                                <a class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-white"><b><%= skinName %></b></a>
                              <% } else { %>
                                <a class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-white"><%= skinName %></a>
                              <% } %>
                            </li>
                          <% }); %>
                        </ul>
                      </div>
                    </div>
                  <% } else { %>
                    No details available for skins.
                  <% } %>
                </td>
                <td class="border border-gray-600 px-4 py-2"><%= accountDetails.price %>€</td>
              <% } else { %>
                <td class="border px-4 py-2" colspan="8">No details available for this account.</td>
              <% } %>
            </tr>
          <% }); %>
        <% } %>
      </tbody>
    </table>
  </div>

  <div id="ordersRpTable" class="overflow-x-auto hidden">
    <table class="table-auto border-collapse border border-gray-600">
      <thead class="bg-gray-800 text-white">
        <tr>
          <th class="px-4 py-2">Order Date</th>
          <th class="px-4 py-2">Username</th>
          <th class="px-4 py-2">RP Amount</th>
          <th class="px-4 py-2">Price</th>
          <th class="px-4 py-2">Status</th>
        </tr>
      </thead>
      <tbody class="text-white bg-gray-900">
        <% orders_rp.forEach((order) => { %>
          <tr>
            <td class="border border-gray-600 px-4 py-2"><%= order.formattedDate %></td>
            <td class="border border-gray-600 px-4 py-2"><%= order.summoners_id %></td>
            <td class="border border-gray-600 px-4 py-2"><%= order.name %></td>
            <td class="border border-gray-600 px-4 py-2"><%= order.price %>€</td>
            <td class="border border-gray-600 px-4 py-2"><%= order.status %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <nav class="mt-4" aria-label="Page navigation">
    <ul class="pagination justify-content-center text-center">
      <% for (let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= currentPage === i ? 'active' : '' %>">
          <a class="page-link bg-blue-700 rounded p-2" href="/myPurchases?page=<%= i %>"><%= i %></a>
        </li>
      <% } %>
    </ul>
  </nav>
</div>

<script nonce="<%= nonce %>">
  document.getElementById('toggleButton').addEventListener('click', function() {
    const accountsTable = document.getElementById('accountsPurchasedTable');
    const ordersRpTable = document.getElementById('ordersRpTable');
    if (accountsTable.classList.contains('hidden')) {
      accountsTable.classList.remove('hidden');
      ordersRpTable.classList.add('hidden');
      toggleButton.textContent = 'Show RP Orders'
    } else {
      accountsTable.classList.add('hidden');
      ordersRpTable.classList.remove('hidden');
      toggleButton.textContent = 'Show Accounts Orders'
    }
  });
</script>

<%- include('partials/MasterFooter') %>

