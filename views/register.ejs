<%- include('partials/MasterHeader') %>
<title>MisterySmurfs - Register</title>
</div>
<div class="grid grid-cols-10">
    <div class="col-span-10">
        <div class="flex justify-center">
            <div class="w-full max-w-xs bg-white rounded-lg shadow-md p-8">
                <h2 class="text-2xl font-bold text-black mb-4 text-center">Registration</h2>
                <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
                    <ul class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4">
                        <% errors.forEach(function(error) { %>
                            <li class="list-disc"><%= error %></li>
                        <% }); %>
                    </ul>
                <% } %>
                <% if (typeof successMessage !== 'undefined' && successMessage) { %>
                    <p class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4"><%= successMessage %></p>
                <% } %>
                <form action="/register" method="post">
                    <div class="mb-4">
                        <label for="username" class="block text-gray-700 text-sm font-bold mb-2">Username</label>
                        <input class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" id="username" name="username" type="text" placeholder="Username" required>
                    </div>
                    <div class="mb-4">
                        <label for="email" class="block text-gray-700 text-sm font-bold mb-2">Email</label>
                        <input class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" id="email" name="email" type="email" placeholder="Email" required>
                    </div>
                    <div class="mb-4">
                        <label for="password" class="block text-gray-700 text-sm font-bold mb-2">Password</label>
                        <input type="password" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" id="password" name="password" placeholder="Password" required>
                    </div>
                    <div class="mb-4">
                        <label for="confirmPassword" class="block text-gray-700 text-sm font-bold mb-2">Confirm Password</label>
                        <input type="password" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" id="confirmPassword" name="confirmPassword" placeholder="Confirm Password" required>
                    </div>
                    <button type="submit" class="w-full py-2 px-4 bg-indigo-600 text-white rounded-md hover:bg-indigo-500 focus:outline-none focus:bg-indigo-500">Register</button>
                </form>
                <p class="mt-4 text-sm text-indigo-600 "> <a href="/login" class="text-indigo-600 hover:underline">Already have an account? Login</a></p>
            </div>
        </div>
    </div>
</div>
<%- include('partials/MasterFooter') %>
