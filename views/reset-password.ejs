<%- include('partials/MasterHeader') %>
<title>Reset Password</title>
</div>
<div class="grid grid-cols-10">
    <div class="col-span-10">
        <div class="flex justify-center">
            <div class="w-full max-w-xs bg-white rounded-lg shadow-md p-8">
                <h2 class="text-2xl font-bold text-black mb-4 text-center">Reset Password</h2>
                <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
                    <div class="mb-4 rounded bg-red-100 p-3 text-sm text-red-700">
                        <% errors.forEach(function(error) { %>
                            <p><%= error %></p>
                        <% }); %>
                    </div>
                <% } %>
                <form method="post" action="/reset-password">
                    <input type="hidden" name="resetToken" value="<%= resetToken %>">
                    <div class="mb-4">
                        <label for="password" class="block text-gray-700 text-sm font-bold mb-2">New Password:</label>
                        <input type="password" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" name="password" id="password" placeholder="New Password" required>
                    </div>
                    <button type="submit" class="w-full py-2 px-4 bg-indigo-600 text-white rounded-md hover:bg-indigo-500 focus:outline-none focus:bg-indigo-500">Reset Password</button>
                </form>
            </div>
        </div>
    </div>
</div>
<%- include('partials/MasterFooter') %>
