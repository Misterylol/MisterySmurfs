<%- include('partials/MasterHeader') %>
<title>MisterySmurfs - Forgot Password</title>
</div>
<div class="grid grid-cols-10">
    <div class="col-span-10">
        <div class="flex justify-center">
            <div class="w-full max-w-xs bg-white rounded-lg shadow-md p-8">
                <h2 class="text-2xl font-bold text-black mb-4 text-center">Forgot Password</h2>
                <form method="POST" action="/forgot-password">
                    <div class="mb-4">
                        <label for="email" class="block text-gray-700 text-sm font-bold mb-2">Email</label>
                        <input type="email" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" id="email" name="email" placeholder="Email" required>
                    </div>
                    <button type="submit" class="w-full py-2 px-4 bg-indigo-600 text-white rounded-md hover:bg-indigo-500 focus:outline-none focus:bg-indigo-500">Reset Password</button>
                </form>
                <p class="mt-3 text-sm text-indigo-600"><a href="/login" class="text-indigo-600 hover:underline">Back to Login</a></p>
            </div>
        </div>
    </div>
</div>
<%- include('partials/MasterFooter') %>
