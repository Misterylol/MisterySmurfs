<div class="grid grid-cols-12 gap-4">
    <div class="col-span-12 md:col-span-9">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <% if (cartItems.length === 0) { %>
                <div class="col-span-3 md:col-span-1">
                    <div class="bg-blue-100 text-blue-900 p-4">
                        No items in the cart.
                    </div>
                </div>
            <% } else { %>
                <% cartItems.forEach(account => { %>
                    <div class="col-span-1 md:col-span-1 mb-3">
                        <div class="bg-gray-900 relative">
                          
                          <div class="card-header relative">
                            <% 
                            // Determine the image URL based on the account's skin
                            var imageURL = 'https://raw.communitydragon.org/14.9/plugins/rcp-be-lol-game-data/global/default/v1/' + account.highestRarityTilePath0;
                            var uniqueId = 'show-skins-toggle-' + account.id; // Generate a unique ID
                            %>
                            <img src="<%= imageURL %>" class="card-img-top" alt="Buy <%= account.skinNames %>">
                            <input type="checkbox" id="<%= uniqueId %>" class="hide-checkbox">
                            <label for="<%= uniqueId %>" class="absolute top-1 right-1 z-10 bg-gray-800 text-white px-2 py-1 rounded-lg cursor-pointer label-top-right ">SHOW SKINS</label>
                            <div class="absolute top-1 left-1 z-10 bg-gray-900 text-white px-2 py-1 rounded-lg skin-names">
                              <% account.skinNames.forEach(skinName => { %>
                                <div>
                                  <% if (account.highestRarityName.includes(skinName)) { %>
                                    <b><%= skinName %></b>
                                  <% } else { %>
                                    <%= skinName %>
                                  <% } %>
                                </div>
                              <% }); %>
                            </div>
                          </div>
                            <div class="p-4">
                                <p class="flex items-center text-white mb-2">
                                    <i class="fas fa-level-up-alt mr-2 icon"></i>
                                    <span class="font-bold">Level: <span class="font-normal"><%= account.level %> </span></span>
                                </p>
                                <p class="flex items-center text-white mb-2">
                                    <i class="fas fa-globe mr-2 icon"></i>
                                    <span class="font-bold">Region: <span class="font-normal"><%= account.region %> </span></span>
                                </p>
                                <p class="flex items-center text-white mb-2">
                                    <img src="https://raw.communitydragon.org/latest/plugins/rcp-fe-lol-store/global/default/storefront/addon/public/img/sprite-source/lcu-be-svg.svg" alt="Blue essence" class="icon">
                                    <span class="font-bold">Blue Essence: <span class="font-normal"><%= (account.blueessence >= 10000) ? (Math.floor(account.blueessence / 10000) * 10000 + '+') : '<10,000' %></span> </span>
                                </p>
                                <p class="flex items-center text-white">
                                    <i class="fas fa-shield-alt mr-2 icon"></i>
                                    <span class="font-bold">Lifetime Warranty</span>
                                </p>
                            </div>
                            <div class="p-4 bg-gray-900 flex justify-between items-end">
                                <p class="price-label-cart">Price: <%= account.price %>€</p>
                                <button class="bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded delete-button" data-item-id="<%= account.id %>">Remove</button>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </div>
    <div class="col-span-12 md:col-span-3">
        <div class="bg-gray-900 shadow-md rounded-md p-4">
            <h5 class="text-xl mb-4">Checkout</h5>
            <hr class="mb-4">
            <form action="Cart/submit-order" method="post">
                <div class="mb-4">
                    <div class="flex justify-between items-center mb-2">
                        <label for="totalPrice" class="text-lg">Total Price:</label>
                        <p id="totalPrice" class="total-price text-2xl mb-0 font-bold"><%= totalPrice %>€</p>
                    </div>
                    <div id="discountedSection" class="hidden">
                        <div class="flex justify-between items-center mb-2">
                            <label class="text-lg" id="percentageDiscount"></label>
                            <span class="total-price text-2xl mb-0 font-bold" id="discountedAmount"></span>
                        </div>
                        <div class="flex justify-between items-center mb-2">
                            <label class="text-lg">New Total:</label>
                            <span class="total-price text-2xl mb-0 font-bold" id="newTotal"></span>
                        </div>
                        <input type="hidden" id="appliedCoupon" name="appliedCoupon">
                    </div>
                    <div id="couponError" class="text-red-500"></div>
                </div>
            
                <div class="mb-4 grid grid-cols-12 items-center">
                    <div class="col-span-8">
                        <input type="text" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline form-control" id="couponCode" name="couponCode" placeholder="Insert Coupon Code">
                    </div>
                    <div class="col-span-4 flex justify-end md:justify-center">
                        <button type="button" class="bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded-full applyCoupon" id="applyCoupon">Apply</button>
                    </div>
                </div>
                
            
                <button type="submit" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded w-full">
                    <i class="fab fa-cc-stripe"></i> Pay using Stripe
                </button>
            </form>
            <div class="mt-4 text-center">
                <p class="mb-1">Prefer other payment methods?</p>
                <p class="mb-0">
                    Check our
                    <a href="https://discord.gg/QXq3m4jAqB" target="_blank" class="text-blue-500 underline">
                       Discord</a>
                    for more options.
                </p>
            </div>
        </div>
    </div>
</div>
